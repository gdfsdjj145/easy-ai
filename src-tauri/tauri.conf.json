{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Easy AI Workstation",
  "version": "0.1.10",
  "identifier": "com.dujiajian.easyai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Easy AI Workstation",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCM0ZEMURGMUI0NUE1MDQKUldRRXBVVWIzOUUvVzB4cmVJT3ZCKy9VazVMR1dHbXlYTm9HZE1HVEg1V284M1Jjdk9RVGVpd0sK",
      "endpoints": [
        "https://github.com/gdfsdjj145/easy-ai/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
